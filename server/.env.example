# Скопируйте в .env и поправьте под себя.
# Нужен только worker.py (server.py с БД не работает вообще).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=admin

# Сколько строк тянуть с сервера БД за один round-trip при потоковой выгрузке.
# Больше — меньше сетевых обращений, но больше памяти на пачку. По умолчанию 2000.
DB_STREAM_BATCH_SIZE=2000

# Язык собственных сообщений сервера (наши тексты, не сырые ошибки БД/Postgres): ru или en.
LANGUAGE=ru

# Настройки самого сервера
MAX_WORKERS=3
PORT=8000
# По умолчанию сервер слышен только с этого же компьютера. Чтобы дать доступ
# с других машин в локальной сети — 0.0.0.0 (тогда доступ ограничивайте на уровне
# сети/файрвола самостоятельно, приложение само авторизацию не делает).
HOST=127.0.0.1

# Сколько секунд ждать вспомогательные процессы (список значений параметра,
# список колонок для конструктора) — если БД у вас медленная даже на таких
# лёгких запросах, увеличьте.
HELPER_TIMEOUT_SECONDS=15

# Разделитель колонок в CSV. По умолчанию ";" — так его сразу корректно открывает
# Excel в большинстве не-английских локалей (где "," — десятичный разделитель).
CSV_DELIMITER=;

# Где хранить конфиги отчётов и результаты выгрузок. Значения ниже — то же самое,
# что и так стоит по умолчанию (рядом с server.py), если вообще не задавать эти
# переменные. Можно указать относительный путь (считается от папки server/) или
# абсолютный — особенно полезно при установке через npm, где server.py оказывается
# внутри node_modules, а эту папку принято сносить и переустанавливать не задумываясь:
# CONFIGS_DIR=../../my-reports-data/configs
# RESULTS_DIR=../../my-reports-data/results
CONFIGS_DIR=configs
RESULTS_DIR=results
